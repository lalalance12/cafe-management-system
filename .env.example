# Copy this file to `.env.local` and fill in the values. `.env.local` is
# git-ignored. Do not commit secrets.
#
# All variables are validated at module load time by `src/lib/env.ts` —
# if a value is missing the app will refuse to start with a readable error.

# --- Supabase ----------------------------------------------------------------

# URL of your Supabase project (Project Settings -> API -> Project URL).
# Example: https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_URL=

# Anon (public) API key. Safe to expose in the browser bundle as long as
# Row Level Security is enabled on every table.
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service role key. Bypasses RLS. NEVER expose this to the browser. Used
# only by `src/lib/supabase/admin.ts`, which is server-only.
SUPABASE_SERVICE_ROLE_KEY=
